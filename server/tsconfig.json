{
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "forceConsistentCasingInFileNames": true,
    "removeComments": true,
    "esModuleInterop": true,
    "module": "commonjs",
    "target": "es6",
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts", "src/types/*.ts"],
  "exclude": ["node_modules", "test", "dist", "**/*spec.ts"]
}
