{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "forceConsistentCasingInFileNames": true,
    "removeComments": true,
    "esModuleInterop": true,
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "es6",
    "strict": true,
    "skipLibCheck": true,
    "lib": ["es6", "dom", "es2022"],
    "typeRoots": ["./node_modules/@types"]
  },
  "include": ["src/**/*.ts", "src/types/*.ts"],
  "exclude": ["node_modules", "test", "dist", "**/*spec.ts"]
}
